# Normalize all text files to LF in the repo
* text=auto eol=lf

# Kotlin / Java / Gradle / XML / Compose
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.gradle text eol=lf
*.xml text eol=lf
*.properties text eol=lf

# Markdown / JSON / YAML
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files (never normalized)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.mp4 binary
*.keystore binary
*.jks binary
*.aab binary
*.apk binary
